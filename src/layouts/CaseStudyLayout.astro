---
import BaseLayout from './BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';

interface Props {
  org: string;
  role: string;
  year: string;
  title?: string;
}

const { org, role, year, title } = Astro.props;
const pageTitle = title || `${org} — Jason Ferrara`;
---

<BaseLayout title={pageTitle}>
  <article class="case-study">
    <header class="cs-header">
      <div class="container">
        <div class="cs-meta">
          <span class="cs-org">{org}</span>
          <span class="cs-divider">/</span>
          <span class="cs-role">{role}</span>
          <span class="cs-divider">/</span>
          <span class="cs-year">{year}</span>
        </div>
      </div>
    </header>

    <div class="cs-body container">
      <slot />
    </div>

    <ContactCTA />

    <footer class="cs-footer container">
      <a href="/" class="cs-back">&larr; Back to work</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .case-study {
    padding-bottom: 2rem;
  }

  .cs-header {
    padding: 6rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3.5rem;
  }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cs-org {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .cs-role,
  .cs-year {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .cs-divider {
    color: var(--color-border);
    font-size: 0.85rem;
  }

  .cs-body {
    max-width: 48rem;
  }

  /* Section styling via global selectors scoped to .cs-body */
  .cs-body :global(section) {
    margin-bottom: 3.5rem;
  }

  .cs-body :global(section:last-of-type) {
    margin-bottom: 0;
  }

  .cs-body :global(.cs-section-label) {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    display: block;
  }

  .cs-body :global(.cs-section-title) {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .cs-body :global(p) {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .cs-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .cs-body :global(.cs-scope-grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 2rem;
  }

  .cs-body :global(.cs-scope-item) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cs-body :global(.cs-scope-label) {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .cs-body :global(.cs-scope-value) {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .cs-body :global(ul) {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cs-body :global(li) {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .cs-body :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
  }

  .cs-body :global(.cs-metrics) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .cs-body :global(.cs-metric) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .cs-body :global(.cs-metric-value) {
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
  }

  .cs-body :global(.cs-metric-label) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  .cs-body :global(.cs-visuals) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cs-body :global(.cs-visual) {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .cs-body :global(.cs-visual img) {
    width: 100%;
    display: block;
  }

  .cs-body :global(.cs-visual-caption) {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    padding: 0.75rem 1rem;
    background: var(--color-card-bg);
    border-top: 1px solid var(--color-border);
  }

  .cs-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .cs-back {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .cs-back:hover {
    color: var(--color-text);
  }

  @media (max-width: 700px) {
    .cs-header {
      padding: 4rem 0 2rem;
      margin-bottom: 2.5rem;
    }

    .cs-body :global(.cs-scope-grid) {
      grid-template-columns: 1fr;
    }

    .cs-body :global(.cs-metrics) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
