---
interface Props {
  title?: string;
}

const { title = 'Jason Ferrara — Product Design Director' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Work', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const isHomepage = currentPath === '/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class:list={['nav', { scrolled: !isHomepage }]}>
      <div class:list={['nav-inner', 'container', { 'logo-visible': !isHomepage }]}>
        <a href="/" class:list={['nav-logo', { visible: !isHomepage }]}>Jason Ferrara</a>
        <span class="nav-divider"></span>
        <ul class="nav-links">
          {navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
    <div class="nav-spacer"></div>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <p>&copy; {new Date().getFullYear()} Jason Ferrara</p>
      </div>
    </footer>
    <script>
      const nav = document.querySelector('.nav') as HTMLElement | null;
      const navInner = document.querySelector('.nav-inner');
      const navLogo = document.querySelector('.nav-logo');
      const heroHeading = document.querySelector('.hero-block h1');

      // Only add scroll behavior on the homepage (has hero heading)
      if (nav && heroHeading && navLogo) {
        window.addEventListener('scroll', () => {
          const headingRect = heroHeading.getBoundingClientRect();
          const navHeight = nav.offsetHeight;
          const pastHeading = headingRect.bottom < navHeight;

          nav.classList.toggle('scrolled', pastHeading);
          navLogo.classList.toggle('visible', pastHeading);
          navInner?.classList.toggle('logo-visible', pastHeading);
        }, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .nav.scrolled {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
    transition: gap 0.3s ease;
  }

  .nav-inner.logo-visible {
    gap: 2rem;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
    opacity: 0;
    transform: translateY(8px);
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: opacity 0.3s ease, transform 0.3s ease, max-width 0.3s ease;
    pointer-events: none;
  }

  .nav-logo.visible {
    opacity: 1;
    transform: translateY(0);
    max-width: 12rem;
    pointer-events: auto;
  }

  .nav-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .nav-inner.logo-visible .nav-divider {
    opacity: 1;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }

  .nav-spacer {
    height: var(--nav-height);
  }

  main {
    flex: 1;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-inner p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
