---
interface Props {
  variant?: 'default' | 'case-study';
}

const { variant = 'default' } = Astro.props;
---

<section class="cta-module">
  <div class:list={['cta-inner', { 'cta-card': variant === 'case-study' }]}>
    {variant === 'case-study' ? (
      <>
        <h2 class="cta-title animate">Want to Go Deeper?</h2>
        <p class="cta-body animate" style="--delay: 0.1s">This overview only scratches the surface. I'm always open to discussing the decisions, constraints, and collaboration that shaped the work in detail.</p>
      </>
    ) : (
      <>
        <h2 class="cta-title animate">Let's Connect</h2>
        <p class="cta-body animate" style="--delay: 0.1s">Most of my work happens at moments of change; when platforms are evolving and clarity matters.</p>
        <p class="cta-body animate" style="--delay: 0.15s">If that sounds familiar, I'd be glad to connect.</p>
      </>
    )}
    <div class="cta-links animate" style="--delay: 0.2s">
      <a href="mailto:jsferrara@gmail.com" class="cta-link">jsferrara@gmail.com</a>
      <a href="https://www.linkedin.com/in/jason-ferrara-ux/" target="_blank" rel="noopener noreferrer" class="cta-link">LinkedIn</a>
    </div>
  </div>
</section>

<style>
  .cta-module {
    padding: 0 2rem;
    margin-top: 2rem;
  }

  .cta-inner {
    text-align: center;
    padding: 3.5rem 3rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  .cta-card {
    background: var(--color-card-bg);
    border-radius: 16px;
  }

  .cta-title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .cta-body {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0.25rem;
  }

  .cta-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 500;
    font-size: 0.95rem;
    color: #fff;
    padding: 0.65rem 1.5rem;
    border: none;
    border-radius: 999px;
    background: #1a1a1a;
    transition: background 0.2s, box-shadow 0.2s;
  }

  .cta-link:hover {
    background: #333;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 700px) {
    .cta-inner {
      padding: 2.5rem 1.5rem;
    }

    .cta-links {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
