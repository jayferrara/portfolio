---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
---

<BaseLayout title="CLEAR — Jason Ferrara">
  <article class="case-study">

    <!-- Hero -->
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <img src="/images/projects/clear-logo.png" alt="CLEAR" class="hero-logo" />
          <h1>Transforming CLEAR for Enterprise</h1>
          <div class="hero-meta">
            <span class="meta-detail">Director, Product Design & Innovation</span>
            <span class="meta-sep">/</span>
            <span class="meta-detail">2023–Present</span>
          </div>
          <p>CLEAR entered enterprise identity verification with strong ambition; but without enterprise-grade infrastructure.</p>
          <p>I led the transformation of CLEAR1 across both sides of the identity platform: <strong>consumer verification performance</strong> and <strong>enterprise platform modernization</strong>.</p>
          <p>Today, CLEAR1 supports <strong>120+ partners</strong> across healthcare, workforce, financial services, and consumer ecosystems.</p>
        </div>
        <div class="hero-visual">
          <img src="/images/clear/DevicePortrait_C1.png" alt="CLEAR verification flow on mobile device" class="hero-device-img" />
        </div>
      </div>
    </section>

    <!-- Evolving the Verification Flow -->
    <section class="cs-section cs-section-alt container">
      <span class="cs-label">Consumer Verification</span>
      <h2 class="cs-heading">Consumer Flow Enhancements</h2>
      <p class="cs-intro">Identity verification depends on trust, speed, and precision across a complex set of backend dependencies. I led efforts to streamline CLEAR's consumer verification lifecycle by addressing not only the front-end journey, but the underlying orchestration of identity checks, failure states, and recovery paths. By reducing systemic friction across the end-to-end flow, we improved completion rates and shortened verification time while strengthening user confidence at critical moments.</p>

      <div class="impact-grid impact-grid-3col">
        <div class="impact-metric">
          <span class="impact-delta">+30pp</span>
          <span class="impact-label">Completion Rate</span>
          <span class="impact-range">52% <span class="impact-arrow">&rarr;</span> 82%</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;49%</span>
          <span class="impact-label">Avg Verification Time</span>
          <span class="impact-range">220s <span class="impact-arrow">&rarr;</span> 112s</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;56%</span>
          <span class="impact-label">Capture Retries</span>
          <span class="impact-range">2.7 avg <span class="impact-arrow">&rarr;</span> 1.2 avg</span>
        </div>
      </div>

      <span class="cs-sublabel">Focus Areas</span>

      <div class="features-grid">
        <div class="feature">
          <div class="feature-image">
            <img src="/images/clear/Selfie.png" alt="CLEAR biometric capture — selfie verification flow" />
          </div>
          <h3>Biometric Capture Optimization</h3>
          <p>Redesigned the biometric capture sequence to reduce user hesitation and technical failure. Introduced real-time guidance overlays, environmental quality checks, and progressive disclosure of instructions — resulting in higher first-attempt success rates across device types.</p>
        </div>
        <div class="feature">
          <div class="feature-image">
            <img src="/images/clear/Consent.png" alt="CLEAR consent and data-sharing screen" />
          </div>
          <h3>Trust & Consent Reframing</h3>
          <p>Reframed consent and data-sharing screens from legal formality into moments of transparency. Simplified language, introduced contextual explanations of why each permission matters, and designed progressive consent flows that built user confidence instead of triggering abandonment.</p>
        </div>
        <div class="feature">
          <div class="feature-image">
            <img src="/images/clear/Error.png" alt="CLEAR intelligent error recovery flow" />
          </div>
          <h3>Intelligent Error Recovery</h3>
          <p>Mapped failure states across the verification pipeline and designed contextual recovery paths that adapt to the type and severity of each error. Replaced generic dead-ends with guided re-entry points — reducing drop-off at critical failure moments and keeping users in-flow.</p>
        </div>
      </div>
    </section>

    <!-- Partner Console -->
    <section class="cs-section cs-section-alt container">
      <h2 class="cs-heading">Partner Console: Scaling the Identity Ecosystem</h2>
      <p class="cs-intro">As CLEAR expanded into a multi-vertical B2B2C identity platform, partner organizations required scalable operational tooling to manage verification workflows, compliance, and performance. Existing systems were fragmented and insufficient for enterprise growth.</p>
      <p class="cs-intro cs-intro-secondary">I am currently leading the effort for transforming the Partner Console into a unified, enterprise-grade operational platform. This effort represented approximately 75% of the product roadmap over two quarters and required close partnership with Sales, Customer Success, and Solutions Engineering to align platform capabilities with commercial expansion goals; along with Product and Engineering.</p>

      <div class="impact-grid impact-grid-3col">
        <div class="impact-metric">
          <span class="impact-delta">120+</span>
          <span class="impact-label">Enterprise Partners Supported</span>
          <span class="impact-range">Up from 1</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;21%</span>
          <span class="impact-label">Reduction in Partner Onboarding Time</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;42%</span>
          <span class="impact-label">Decrease in Operational Escalations</span>
        </div>
      </div>

      <span class="cs-sublabel">Focus Areas</span>

      <div class="showcase" id="partner-showcase">
        <button class="showcase-arrow showcase-prev" aria-label="Previous feature" tabindex="0">&lsaquo;</button>
        <div class="showcase-layout">
          <div class="showcase-image-wrap">
            <img src="/images/clear/Templates.png" class="screen-img active" data-slide="0" alt="CLEAR configurable identity platform templates" />
            <img src="/images/clear/VerificationDetails.png" class="screen-img" data-slide="1" alt="CLEAR verification details and risk insight interface" />
            <img src="/images/clear/Analytics.png" class="screen-img" data-slide="2" alt="CLEAR embedded analytics and performance dashboard" />
          </div>
          <div class="showcase-copy-col">
            <div class="showcase-content active" data-slide="0">
              <h3>Configurable Identity Platform</h3>
              <p>Transformed project setup from rigid, linear workflows into a configurable identity platform powered by modular checks and use-case–based templates. This shift enabled partners to launch with one-click configuration aligned to common industry needs while retaining granular control over verification logic. The result was faster onboarding, reduced engineering dependency, and a scalable framework for continuous capability expansion.</p>
            </div>
            <div class="showcase-content" data-slide="1">
              <h3>Operational Transparency & Risk Insight</h3>
              <p>Elevated the Partner Console into an investigation-first command center, enabling partners to quickly diagnose failures, interpret fraud signals, and take decisive action. Introduced structured filtering, contextual failure explanations, embedded risk intelligence, and delivered a 6&times; improvement in search performance; significantly reducing latency during failure investigations and accelerating operational response across enterprise-scale partner environments.</p>
            </div>
            <div class="showcase-content" data-slide="2">
              <h3>Embedded Performance Visibility</h3>
              <p>Integrated real-time performance insights directly into the console, giving partners direct visibility into verification trends, drop-off patterns, and operational health. Reduced reliance on external reporting and empowered teams to monitor and optimize performance independently.</p>
            </div>
          </div>
        </div>
        <button class="showcase-arrow showcase-next" aria-label="Next feature" tabindex="0">&rsaquo;</button>
      </div>
    </section>

    <ContactCTA />

  </article>
</BaseLayout>

<style>
  /* Page Gradient */
  .case-study {
    background: linear-gradient(180deg, #dbe4f0 0%, #f4f0eb 35%, #eef1f5 65%, #f7f5f2 100%);
  }

  /* Hero */
  .hero {
    padding: 8rem 0 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    margin-top: -0.5rem;
  }

  .hero-logo {
    height: 35px;
    width: auto;
    margin-bottom: 1.25rem;
  }

  .meta-detail {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .meta-sep {
    font-size: 0.8rem;
    color: var(--color-border);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .hero-copy > p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-scope {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hero-scope li {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
    padding-left: 1.25rem;
    position: relative;
  }

  .hero-scope li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
  }

  .hero-tracks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0.75rem 0 1.5rem;
  }

  .track {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .track-num {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .track strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .track span:not(.track-num) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .hero-stat {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .hero-stat strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Hero Device Image */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-device-img {
    width: 110%;
    height: auto;
    display: block;
  }

  /* Section */
  .cs-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .cs-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .cs-heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .cs-intro {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 42rem;
    margin-bottom: 3.5rem;
  }

  .cs-intro-secondary {
    margin-top: -2.5rem;
  }

  .cs-section-alt {
    border-top: 1px solid var(--color-border);
  }

  .cs-sublabel {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Features Grid (Consumer section) */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-image {
    margin-bottom: 1.25rem;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .feature-image img {
    width: 100%;
    display: block;
  }

  .feature h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .feature p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* Showcase (Partner Console) */
  .showcase {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .showcase-layout {
    flex: 1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: center;
    min-width: 0;
  }

  .showcase-image-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .screen-img {
    width: 100%;
    display: block;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* First image is always relative to hold container size */
  .screen-img:first-child {
    position: relative;
  }

  /* All others stack on top */
  .screen-img:not(:first-child) {
    position: absolute;
    top: 0;
    left: 0;
  }

  .screen-img.active {
    opacity: 1;
  }

  /* Copy */
  .showcase-copy-col {
    position: relative;
  }

  .showcase-content {
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  /* First content block is always relative to hold container size */
  .showcase-content:first-child {
    position: relative;
  }

  .showcase-content:not(:first-child) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
  }

  .showcase-content.active {
    opacity: 1;
    pointer-events: auto;
  }

  .showcase-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .showcase-content p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  /* Arrow Controls */
  .showcase-arrow {
    flex-shrink: 0;
    z-index: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
    padding: 0 0 1px 0;
  }

  .showcase-arrow:hover,
  .showcase-arrow:focus-visible {
    border-color: var(--color-text);
    background: var(--color-text);
    color: var(--color-bg);
    outline: none;
  }

  /* Impact */
  .impact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem 4rem;
    margin-bottom: 3.5rem;
  }

  .impact-grid-3col {
    grid-template-columns: repeat(3, 1fr);
  }

  .impact-metric {
    display: flex;
    flex-direction: column;
  }

  .impact-delta {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
  }

  .impact-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-top: 0.75rem;
  }

  .impact-range {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: 0.3rem;
    opacity: 0.5;
  }

  .impact-arrow {
    display: inline-block;
    margin: 0 0.15em;
    opacity: 0.5;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero {
      padding: 5rem 0 3rem;
    }
  }

  @media (max-width: 700px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .showcase-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .impact-grid {
      gap: 2.5rem 2rem;
    }

    .impact-grid-3col {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const showcase = document.getElementById('partner-showcase');
  if (showcase) {
    const screens = showcase.querySelectorAll<HTMLElement>('.screen-img');
    const copies = showcase.querySelectorAll<HTMLElement>('.showcase-content');
    const prevBtn = showcase.querySelector('.showcase-prev');
    const nextBtn = showcase.querySelector('.showcase-next');
    const total = screens.length;
    let current = 0;
    let isTransitioning = false;

    function goTo(next: number) {
      if (isTransitioning || next === current) return;
      if (next < 0) next = total - 1;
      if (next >= total) next = 0;
      isTransitioning = true;

      // Fade out current
      screens[current].classList.remove('active');
      copies[current].classList.remove('active');

      // After fade-out completes, activate next
      setTimeout(() => {
        screens[next].classList.add('active');
        copies[next].classList.add('active');
        current = next;

        // Allow next transition after fade-in
        setTimeout(() => {
          isTransitioning = false;
        }, 300);
      }, 300);
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    // Keyboard support
    showcase.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });
  }
</script>
