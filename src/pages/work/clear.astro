---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="CLEAR — Jason Ferrara">
  <article class="case-study">

    <!-- Hero -->
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <img src="/images/projects/clear-logo.png" alt="CLEAR" class="hero-logo" />
          <h1>Transforming CLEAR for Enterprise</h1>
          <div class="hero-meta">
            <span class="meta-detail">Director, Product Design & Innovation</span>
            <span class="meta-sep">/</span>
            <span class="meta-detail">2023–Present</span>
          </div>
          <p>CLEAR entered enterprise identity verification with strong ambition; but without enterprise-grade infrastructure.</p>
          <p>I led the transformation of CLEAR1 across both sides of the identity platform: <strong>consumer verification performance</strong> and <strong>enterprise platform modernization</strong>.</p>
          <p>Today, CLEAR1 supports <strong>120+ partners</strong> across healthcare, workforce, financial services, and consumer ecosystems.</p>
        </div>
        <div class="hero-visual">
          <div class="device-composite">
            <div class="device device-mobile">
              <div class="device-bar">
                <span class="device-dot"></span>
                <span class="device-dot"></span>
                <span class="device-dot"></span>
              </div>
              <div class="device-screen">
                <div class="screen-placeholder">
                  <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="18" r="10" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M18 16C18 16 20 22 24 22C28 22 30 16 30 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <rect x="14" y="32" width="20" height="6" rx="3" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="10" y="42" width="28" height="2" rx="1" fill="currentColor" opacity="0.15"/>
                  </svg>
                  <span>Verification Flow</span>
                </div>
              </div>
            </div>
            <div class="device device-dashboard">
              <div class="device-bar">
                <span class="device-dot"></span>
                <span class="device-dot"></span>
                <span class="device-dot"></span>
              </div>
              <div class="device-screen">
                <div class="screen-placeholder">
                  <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="18" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="26" y="4" width="18" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="4" y="18" width="40" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <line x1="4" y1="24" x2="44" y2="24" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                    <line x1="4" y1="28" x2="44" y2="28" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                    <rect x="4" y="38" width="12" height="6" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="20" y="38" width="12" height="6" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                  <span>Console Dashboard</span>
                </div>
              </div>
            </div>
            <div class="device device-detail">
              <div class="device-bar">
                <span class="device-dot"></span>
                <span class="device-dot"></span>
                <span class="device-dot"></span>
              </div>
              <div class="device-screen">
                <div class="screen-placeholder">
                  <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="16" cy="14" r="8" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M28 8h16M28 14h12M28 20h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                    <line x1="4" y1="28" x2="44" y2="28" stroke="currentColor" stroke-width="1" opacity="0.2"/>
                    <rect x="4" y="32" width="40" height="4" rx="2" fill="currentColor" opacity="0.08"/>
                    <rect x="4" y="40" width="28" height="4" rx="2" fill="currentColor" opacity="0.08"/>
                  </svg>
                  <span>Verification Detail</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Evolving the Verification Flow -->
    <section class="cs-section cs-section-alt container">
      <h2 class="cs-heading">Evolving the Verification Flow</h2>
      <p class="cs-intro">Identity verification depends on trust, speed, and precision across a complex set of backend dependencies. I led efforts to streamline CLEAR's consumer verification lifecycle by addressing not only the front-end journey, but the underlying orchestration of identity checks, failure states, and recovery paths. By reducing systemic friction across the end-to-end flow, we improved completion rates and shortened verification time while strengthening user confidence at critical moments.</p>

      <div class="impact-grid impact-grid-3col">
        <div class="impact-metric">
          <span class="impact-delta">+30pp</span>
          <span class="impact-label">Completion Rate</span>
          <span class="impact-range">52% <span class="impact-arrow">&rarr;</span> 82%</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;49%</span>
          <span class="impact-label">Avg Verification Time</span>
          <span class="impact-range">220s <span class="impact-arrow">&rarr;</span> 112s</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">&minus;56%</span>
          <span class="impact-label">Capture Retries</span>
          <span class="impact-range">2.7 avg <span class="impact-arrow">&rarr;</span> 1.2 avg</span>
        </div>
      </div>

      <span class="cs-sublabel">Noteworthy Optimizations</span>

      <div class="features-grid">
        <div class="feature">
          <h3>Biometric Capture Optimization</h3>
          <p>Redesigned the biometric capture sequence to reduce user hesitation and technical failure. Introduced real-time guidance overlays, environmental quality checks, and progressive disclosure of instructions — resulting in higher first-attempt success rates across device types.</p>
        </div>
        <div class="feature">
          <h3>Trust & Consent Reframing</h3>
          <p>Reframed consent and data-sharing screens from legal formality into moments of transparency. Simplified language, introduced contextual explanations of why each permission matters, and designed progressive consent flows that built user confidence instead of triggering abandonment.</p>
        </div>
        <div class="feature">
          <h3>Intelligent Error Recovery</h3>
          <p>Mapped failure states across the verification pipeline and designed contextual recovery paths that adapt to the type and severity of each error. Replaced generic dead-ends with guided re-entry points — reducing drop-off at critical failure moments and keeping users in-flow.</p>
        </div>
      </div>
    </section>

    <!-- Partner Console -->
    <section class="cs-section cs-section-alt container">
      <h2 class="cs-heading">Partner Console: Scaling the Identity Ecosystem</h2>
      <p class="cs-intro">As CLEAR expanded into a multi-vertical B2B2C identity platform, partner organizations required scalable operational tooling to manage verification workflows, compliance, and performance. Existing systems were fragmented and insufficient for enterprise growth.</p>
      <p class="cs-intro cs-intro-secondary">I am currently leading the effort for transforming the Partner Console into a unified, enterprise-grade operational platform. This effort represented approximately 75% of the product roadmap over two quarters and required close partnership with Sales, Customer Success, and Solutions Engineering to align platform capabilities with commercial expansion goals; along with Product and Engineering.</p>

      <div class="impact-grid">
        <div class="impact-metric">
          <span class="impact-delta">120+</span>
          <span class="impact-label">Enterprise Partners Supported</span>
          <span class="impact-range">Up from 1</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">X%</span>
          <span class="impact-label">Reduction in Partner Onboarding Time</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">X%</span>
          <span class="impact-label">Decrease in Operational Escalations</span>
        </div>
        <div class="impact-metric">
          <span class="impact-delta">Xx</span>
          <span class="impact-label">Increase in Partner Activation Throughput</span>
        </div>
      </div>

      <span class="cs-sublabel">Noteworthy Features</span>

      <div class="features-grid">
        <div class="feature">
          <h3>Flexible Identity Orchestration</h3>
          <p>Reframed project configuration from rigid, step-based flows to a flexible orchestration model that separated checks from user steps. This enabled more granular decisioning, supported waterfall logic, and created a scalable foundation for introducing new verification capabilities without increasing user friction.</p>
        </div>
        <div class="feature">
          <h3>Operational Transparency & Risk Insight</h3>
          <p>Transformed the verification experience into an investigation-first interface, enabling partners to quickly diagnose failures, assess fraud signals, and take action with confidence. Introduced richer filtering, clearer failure explanations, and embedded risk context to support high-stakes operational decisions.</p>
        </div>
        <div class="feature">
          <h3>Embedded Performance Visibility</h3>
          <p>Integrated real-time performance insights directly into the console, giving partners direct visibility into verification trends, drop-off patterns, and operational health. Reduced reliance on external reporting and empowered teams to monitor and optimize performance independently.</p>
        </div>
      </div>
    </section>

  </article>
</BaseLayout>

<style>
  /* Page Gradient */
  .case-study {
    background: linear-gradient(180deg, #dbe4f0 0%, #f4f0eb 35%, #eef1f5 65%, #f7f5f2 100%);
  }

  /* Hero */
  .hero {
    padding: 8rem 0 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    margin-top: -0.5rem;
  }

  .hero-logo {
    height: 28px;
    width: auto;
    margin-bottom: 1.25rem;
  }

  .meta-detail {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .meta-sep {
    font-size: 0.8rem;
    color: var(--color-border);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .hero-copy > p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-scope {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hero-scope li {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
    padding-left: 1.25rem;
    position: relative;
  }

  .hero-scope li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
  }

  .hero-tracks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0.75rem 0 1.5rem;
  }

  .track {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .track-num {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .track strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .track span:not(.track-num) {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .hero-stat {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .hero-stat strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Device Composite */
  .device-composite {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .device {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .device-bar {
    display: flex;
    gap: 5px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-card-bg);
  }

  .device-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-border);
  }

  .device-screen {
    padding: 1.25rem;
  }

  .screen-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
  }

  .screen-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.5;
  }

  .screen-placeholder span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .device-mobile {
    grid-row: 1 / 3;
  }

  .device-mobile .device-screen {
    padding: 2.5rem 1.25rem;
  }

  .device-dashboard {
    grid-column: 2;
  }

  .device-detail {
    grid-column: 2;
  }

  /* Section */
  .cs-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .cs-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .cs-heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .cs-intro {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 42rem;
    margin-bottom: 3.5rem;
  }

  .cs-intro-secondary {
    margin-top: -2.5rem;
  }

  .cs-section-alt {
    border-top: 1px solid var(--color-border);
  }

  .cs-sublabel {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .feature p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* Impact */
  .impact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem 4rem;
    margin-bottom: 3.5rem;
  }

  .impact-grid-3col {
    grid-template-columns: repeat(3, 1fr);
  }

  .impact-metric {
    display: flex;
    flex-direction: column;
  }

  .impact-delta {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
  }

  .impact-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-top: 0.75rem;
  }

  .impact-range {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: 0.3rem;
    opacity: 0.5;
  }

  .impact-arrow {
    display: inline-block;
    margin: 0 0.15em;
    opacity: 0.5;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero {
      padding: 5rem 0 3rem;
    }
  }

  @media (max-width: 700px) {
    .device-composite {
      grid-template-columns: 1fr 1.4fr;
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .impact-grid {
      gap: 2.5rem 2rem;
    }

    .impact-grid-3col {
      grid-template-columns: 1fr;
    }
  }
</style>
