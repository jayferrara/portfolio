---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';

const orgs = [
  {
    name: 'CLEAR',
    role: 'Director, Product Design',
    years: '2021–2024',
    image: '/images/home/CLEAR_Tile.png',
    description: 'Led biometric identity verification design across consumer and enterprise platforms, scaling secure experiences to millions of travelers.',
    href: '/work/clear',
  },
  {
    name: 'Audible',
    role: 'Director, User Experience',
    years: '2018–2021',
    image: '/images/home/Audible_Tile.png',
    description: 'Drove a full UX revamp that increased total revenue 3.5% and Originals listening 14%. Pioneered a cross-functional squad model adopted across business units.',
    href: '/work/audible',
  },
  {
    name: 'HBO',
    role: 'User Experience Manager',
    years: '2014–2018',
    image: '/images/home/HBO_Tile.png',
    description: 'Shipped 4 major product initiatives including a patented content discovery feature, platform-wide IA overhaul, Apple tvOS launch, and interactive video player.',
    href: '/work/hbo',
  },
];
---

<BaseLayout>
  <div class="page-gradient">
    <section class="hero-block">
      <div class="hero-inner container">
        <h1>Jason Ferrara</h1>
        <p class="hero-role">Product Design Leader</p>
        <p class="hero-subtitle">I lead with a clear vision for the experience. I bring structure to complexity, align people around what matters, and build platforms that are built to grow.</p>
      </div>
    </section>

    <section class="work container">
      {orgs.map((org) => (
        <a href={org.href} class="org-card">
          <img src={org.image} alt={org.name} class="org-bg" />
          <span class="org-role">{org.role}, {org.years}</span>
        </a>
      ))}
    </section>

    <ContactCTA />
  </div>
</BaseLayout>

<style is:global>
  html {
    background: #f7f5f2 !important;
  }
</style>

<style>
  .page-gradient {
    position: relative;
    background: linear-gradient(180deg, #c9d8ed 0%, #e0e4ed 30%, #eef0f0 60%, #f7f5f2 100%);
  }

  .page-gradient::before {
    content: '';
    position: absolute;
    top: -100vh;
    left: 0;
    right: 0;
    height: 100vh;
    background: #c9d8ed;
  }

  .hero-block {
    padding: 7rem 0 4rem;
    margin-top: calc(-1 * var(--nav-height));
    padding-top: calc(7rem + var(--nav-height));
    margin-bottom: 1.5rem;
  }

  .hero-inner {
    margin-bottom: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-block h1 {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .hero-role {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.5;
    max-width: 40rem;
    color: var(--color-text-secondary);
  }

  .work {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .org-card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
  }

  .org-bg {
    width: 100%;
    display: block;
    opacity: 0.85;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .org-card:hover .org-bg {
    opacity: 1;
    transform: scale(1.04);
  }

  .org-role {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    text-align: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .org-card:hover .org-role {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 700px) {

    .hero-block {
      padding: 3rem 0 3rem;
      padding-top: calc(3rem + var(--nav-height));
      margin-bottom: 2rem;
    }

    .hero-inner {
      margin-bottom: 0;
    }

    .org-bg {
      opacity: 1;
    }

    .org-role {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
