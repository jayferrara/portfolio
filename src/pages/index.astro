---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgs = [
  {
    name: 'CLEAR',
    role: 'Director, Product Design',
    image: '/images/home/CLEAR_Tile.png',
    description: 'Led biometric identity verification design across consumer and enterprise platforms, scaling secure experiences to millions of travelers.',
    href: '/work/clear',
  },
  {
    name: 'Audible',
    role: 'Director, User Experience',
    image: '/images/home/Audible_Tile.png',
    description: 'Drove a full UX revamp that increased total revenue 3.5% and Originals listening 14%. Pioneered a cross-functional squad model adopted across business units.',
    href: '/work/audible',
  },
  {
    name: 'HBO',
    role: 'Lead UX Designer',
    image: '/images/home/HBO_Tile.png',
    description: 'Shipped 4 major product initiatives including a patented content discovery feature, platform-wide IA overhaul, Apple tvOS launch, and interactive video player.',
    href: '/work/hbo',
  },
];
---

<BaseLayout>
  <section class="hero-block">
    <div class="hero-inner container">
      <h1>Jason Ferrara</h1>
      <p class="hero-role">Product Design Leader</p>
      <p class="hero-subtitle">I lead experience vision, influence product roadmaps, and scale design organizations across complex multi-surface platforms.</p>
    </div>
  </section>

  <section class="work container">
    {orgs.map((org) => (
      <a href={org.href} class="org-card">
        <img src={org.image} alt={org.name} class="org-bg" />
        <span class="org-role">{org.role}</span>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero-block {
    background: linear-gradient(180deg, #dbe4f0 0%, #ffffff 100%);
    padding: 5rem 0 4rem;
    margin-top: calc(-1 * var(--nav-height));
    padding-top: calc(5rem + var(--nav-height));
    margin-bottom: 3rem;
  }

  .hero-inner {
    margin-bottom: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-block h1 {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .hero-role {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.5;
    max-width: 40rem;
    color: var(--color-text-secondary);
  }

  .work {
    padding-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .org-card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
  }

  .org-bg {
    width: 100%;
    display: block;
    opacity: 0.4;
    filter: saturate(0) brightness(1.15);
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }

  .org-card:hover .org-bg {
    opacity: 1;
    filter: saturate(1) brightness(1);
    transform: scale(1.04);
  }

  .org-role {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .org-card:hover .org-role {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 700px) {

    .hero-block {
      padding: 3rem 0 3rem;
      padding-top: calc(3rem + var(--nav-height));
      margin-bottom: 2rem;
    }

    .hero-inner {
      margin-bottom: 0;
    }
  }
</style>
